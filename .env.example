# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME="Foggy Nook"

# WhatsApp (fallback default, real value is stored in the `settings` table and editable from Admin)
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Optional: Resend / email provider for order confirmation emails
RESEND_API_KEY=
EMAIL_FROM=orders@yourstore.com


